.container{

  width:100%;

}

.empty{

  padding:40rpx 0;

  color:#999;

  text-align:center;

  font-size:28rpx;

}

.grid{

  display:flex;

  flex-wrap:wrap;

  justify-content:space-between;

}

.item{

  width:48%;

  height:88rpx;

  margin-bottom:20rpx;

  display:flex;

  justify-content:center;

  align-items:center;

  border-radius:16rpx;

  background:#f5f5f5;

  border:2rpx solid #f5f5f5;

  font-size:28rpx;

  color:#333;

  transition:all .2s;

}

.active{

  background:#1677ff;

  color:white;

  border-color:#1677ff;

}
.disabled{

  background:#eeeeee;

  color:#999;

}

.full{

  color:#ff4d4f;

  font-size:22rpx;

  margin-top:8rpx;

}

.selected{

  background:#409EFF;

  color:#fff;

}